            </field>
            <field name="PRAZO" dataType="INTEIRO" allowSearch="S" visibleOnSearch="S">
                <description>Prazo</description>
            </field>
            <field name="TIPOPRAZO" dataType="LISTA" allowSearch="S" visibleOnSearch="S">
                <description>Tipo Prazo</description>
                <fieldOptions>
                    <option value="1">Dias</option>
                    <option value="2">Horas</option>
                    <option value="3">Meses</option>
                </fieldOptions>
            </field>
        </fields>
    </table>

</metadados>
