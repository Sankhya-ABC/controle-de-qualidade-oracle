<?xml version="1.0" encoding="iso-8859-1" ?>
<metadados xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:noNamespaceSchemaLocation="../.gradle/metadados.xsd">

    <table name="BP_TGQPRI" sequenceType="A" sequenceField="PRIORIDADEID">
        <description>Tabela de Prioridades</description>
        <primaryKey>
            <field name="PRIORIDADEID"/>
        </primaryKey>
        <instances>
            <instance name="BpPrioridade">
                <description>Cadastro de Prioridades</description>
            </instance>
        </instances>
        <fields>
